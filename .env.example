MONGO_URI=mongodb://localhost:27017
MONGO_DB=newsscrapper
SCRAPE_INTERVAL_ZERODHA=15
SCRAPE_INTERVAL_TWITTER=30
SCRAPE_INTERVAL_RSS=20
SCRAPE_INTERVAL_LINKEDIN=0
SCRAPE_INTERVAL_SUBSTACK=30

# Comma-separated keywords for tagging
KEYWORDS=nifty,sensex,rbi,fed,inflation,earnings,ipo,stock,market,crypto,bitcoin,gold,rupee,dollar,gdp,budget,sebi,mutual fund,etf,dividend

# Comma-separated RSS feed URLs
RSS_FEEDS=https://economictimes.indiatimes.com/markets/rssfeeds/1977021501.cms,https://www.livemint.com/rss/markets

# Twitter accounts to monitor (comma-separated)
TWITTER_ACCOUNTS=ZeprodhaPulse,monaboradakker,MarketAnalysis

# Substack newsletter URLs (comma-separated)
SUBSTACK_URLS=https://zennivesh.substack.com/,https://91capital.substack.com/

# LinkedIn cookie (li_at value) - set manually after login
LINKEDIN_COOKIE=

# PIB scraper settings
SCRAPE_INTERVAL_PIB=60
PIB_ANALYZE_INTERVAL=120
PIB_ANALYZE_BATCH_SIZE=20

# Anthropic API key for PIB analysis (Claude SDK fallback)
ANTHROPIC_API_KEY=

# AWS S3 for MongoDB backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BACKUP_BUCKET=zenflow-db-backups
